# ─────────────────────────────────────────────────────────────────────────────
# Playbox — configuration d'environnement
# Copie ce fichier en .env et remplis les valeurs.
# ─────────────────────────────────────────────────────────────────────────────

# IP publique fixe de ta machine (visible depuis internet)
# Pour la trouver : https://whatismyip.com
TURN_PUBLIC_IP=1.2.3.4

# Secret partagé entre le backend et coturn pour les credentials HMAC.
# Génère une valeur aléatoire forte, ex :
#   openssl rand -hex 32
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
TURN_SECRET=change_me_with_a_strong_random_secret

# Domaine ou IP utilisé dans les URLs TURN exposées aux clients.
# Si tu n'as pas de domaine, mets la même valeur que TURN_PUBLIC_IP.
TURN_HOST=1.2.3.4

# ─────────────────────────────────────────────────────────────────────────────
# Ports à ouvrir sur ton routeur (redirection de port) :
#   UDP 3478   → STUN + TURN
#   TCP 3478   → TURN over TCP (fallback)
#   UDP 49152-49250 → relay ports coturn
# ─────────────────────────────────────────────────────────────────────────────
